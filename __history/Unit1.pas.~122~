{$R *.dfm}

procedure PrintMemo(Memo: TMemo);
var
  i: integer;
begin
  Printer.BeginDoc;
  try
    for i := 0 to Memo.Lines.Count - 1 do
      Printer.Canvas.TextOut(0, i * Printer.Canvas.TextHeight(Memo.Lines[i]),
        Memo.Lines[i]);
  finally
    Printer.EndDoc;
  end;
end;

procedure TForm1.Button1Click(Sender: TObject);
var
  summand: real;
begin
  if Edit1.Text = EmptyStr then
  begin
    Exit;
  end;

  summand := StrToFloat(Edit1.Text);
  lastSummand:=summand;
  if summand <= 0 then
  begin
    ShowMessage('Summe muss größer als 0 sein.');
    Exit;
  end;

  if RadioButton1.Checked then
  begin
    Steuer7P:= RoundTo(Summand / (7/100+1),-2);
  end
  else if RadioButton2.Checked then
  begin
    Steuer19P:= RoundTo(Summand / (19 / 100 + 1), -2)
  end;

  Edit1.Clear;
  Total := Total + summand;
  Memo1.Lines.Add(IntToStr(Zaehler)+'. '+FloatToStr(summand) + ' €' );
  Edit2.Text := FloatToStr(Total);
  Zaehler:= Zaehler +1;
end;

procedure TForm1.Button2Click(Sender: TObject);
var
  Bar, Rueckgeld, Mwst, Differenz: real;
  Datum: TDate;
  Time: TTime;

begin
  Bar := StrToFloat(Edit5.Text);

  if Total > Bar then
  begin
    Differenz := Total - Bar;

    ShowMessage('Zu wenig. Bitte zahlen Sie noch ' +
      FloatToStr(RoundTo(Abs(Differenz), -2)) + '€');
    Exit;
  end;

  Edit3.Text := FloatToStr(RoundTo(Steuer7P, -2));
  Edit7.Text := FloatToStr(RoundTo(Steuer19P, -2));
  Edit4.Text := FloatToStr(RoundTo(Total - (Steuer7P + Steuer19P), -2));
  Rueckgeld := Bar - Total;

  Memo1.Lines.Add('------------');
  Memo1.Lines.Add('Summe: ' + FloatToStr(RoundTo(Total, -2)) + '€');
  Memo1.Lines.Add('======');
  Memo1.Lines.Add('Mwst-7%: ' + FloatToStr(RoundTo(Steuer7P, -2)) + '€');
  Memo1.Lines.Add('Mwst-19%: ' + FloatToStr(RoundTo(Steuer19P, -2)) + '€');
  Memo1.Lines.Add('Netto: ' + FloatToStr(RoundTo(Total - (Steuer7P + Steuer19P), -2)) + ' €');
  Memo1.Lines.Add('Transaktion: ' + IntToStr(RECHUNGSID));
  RECHUNGSID := RECHUNGSID + 1;
  Memo1.Lines.Add('======');
  Memo1.Lines.Add('Zahlungsmetode: Bar');
  Memo1.Lines.Add('Bar: ' + FloatToStr(Bar) + '€');
  Memo1.Lines.Add('Rückgled: ' + FloatToStr(RoundTo(Rueckgeld, -2)) + '€');
  Memo1.Lines.Add('======');
  Memo1.Lines.Add('Danke für ihren Einkauf');
  Memo1.Lines.Add('Datum/Urzeit: ' + FormatDateTime('dd.mm.yyyy, hh:nn:ss', now)
    + ' Uhr');
  Memo1.Lines.Add('======');

  Edit6.Text := FloatToStr(RoundTo(Rueckgeld, -2));

end;

